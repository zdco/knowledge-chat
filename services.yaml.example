# 服务注册表 - 日志分析模式专用
# 通过对话让 AI 自动生成，或手动编辑
# 使用方法：参考 AI_GUIDE_ANALYZER.md

services:
  # ── 示例 1：基本配置 ────────────────────────────
  # market_gateway:
  #   name: "行情网关"
  #   repo: "/data/repos/market_gateway"
  #   language: "C++"
  #   depends_on: [data_server, config_center]
  #   description: "接收交易所行情数据并分发"

  # ── 示例 2：不同客户对应不同 git 仓库 ──────────
  # trade_engine:
  #   name: "交易引擎"
  #   repo: "https://new-gitlab.example.com/trading/engine.git"   # 默认仓库（最新）
  #   language: "C++"
  #   depends_on: [risk_control, market_gateway]
  #   description: "核心交易撮合引擎"
  #   client_repos:
  #     客户A: "https://old-gitlab.example.com/legacy/trade-engine.git"
  #     客户B: "git@internal-git:trading/engine-v2.git"
  #     客户C:
  #       repo: "/data/customer_code/clientC/trade_engine"
  #       sub_path: "src"

  # ── 示例 3：直接粘贴 GitLab 页面地址 ──────────
  # 自动解析出仓库地址、分支、子路径，不需要手动拆分
  # db_query_server:
  #   name: "数据查询服务"
  #   repo: "http://gitlab.whup.com/UPService-HQSystem/Data_Servers/tree/dev/DbQueryServer"
  #   language: "C++"
  #   depends_on: []
  #   description: "数据查询服务"

  # ── 示例 3：monorepo 子路径 ────────────────────
  # data_server:
  #   name: "数据服务"
  #   repo: "/data/repos/monorepo"
  #   sub_path: "services/data_server"
  #   language: "Java"
  #   depends_on: [database]
  #   description: "数据存储和查询服务"

  # ── 示例 4：远程 git 仓库（自动 clone）─────────
  # auth_service:
  #   name: "认证服务"
  #   repo: "https://gitlab.example.com/backend/auth.git"
  #   language: "Java"
  #   depends_on: []
  #   description: "用户认证和权限管理"

# ── 配置说明 ──────────────────────────────────────
#
# repo 支持三种格式：
#   1. 本地 git 仓库路径
#   2. 远程 git URL（首次使用自动 clone）
#   3. 本地普通目录（非 git，自动复制）
#
# client_repos（可选）：不同客户的代码仓库映射
#   简写：客户名: "仓库地址"
#   完整：客户名:
#           repo: "仓库地址"
#           sub_path: "子路径"
#
# 版本号不需要在配置中写死，用户在对话中提供即可
# AI 会用 switch_service(service="xxx", version="v2.3.1", client="客户A") 加载代码
